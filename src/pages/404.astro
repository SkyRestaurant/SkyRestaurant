---
import BaseLayout from '../layouts/BaseLayout.astro';
import mk from '../i18n/mk.json';
import en from '../i18n/en.json';

const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/en') ? 'en' : 'mk';

const ui = lang === 'en' ? en : mk;

const homeUrl = lang === 'en' ? '/en/' : '/';
---

<BaseLayout title={`404 - ${ui["error.title"]} | Sky Restaurant`} lang={lang}>
  
  <section class="w-full min-h-[100vh] flex flex-col items-center justify-center bg-navbar-bg relative z-10 overflow-hidden px-4">
    
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60vw] h-[60vw] md:w-[40vw] md:h-[40vw] rounded-full border-[0.5px] border-darkbrown/20 pointer-events-none -z-10"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90vw] h-[90vw] md:w-[60vw] md:h-[60vw] rounded-full border-[0.5px] border-darkbrown/10 pointer-events-none -z-10"></div>

    <div id="error-content" class="text-center relative z-10 opacity-0 translate-y-10 transition-all duration-[1200ms] ease-out flex flex-col items-center">
      
      <h1 class="font-display text-[8rem] md:text-[12rem] text-accent-gold leading-none drop-shadow-lg mb-2">
        404
      </h1>
      
      <div class="flex items-center justify-center gap-6 mb-8 w-full">
        <div class="w-12 md:w-24 h-[1px] bg-gradient-to-r from-transparent to-accent-gold"></div>
        <h2 class="text-white font-serif text-xl md:text-3xl uppercase tracking-widest text-center leading-relaxed">
          {ui["error.title"]}
        </h2>
        <div class="w-12 md:w-24 h-[1px] bg-gradient-to-l from-transparent to-accent-gold"></div>
      </div>
      
      <p class="text-lightbrown mb-12 max-w-md md:max-w-xl font-sans font-light tracking-wide text-sm md:text-base">
        {ui["error.desc"]}
      </p>

      <a href={homeUrl} class="group relative inline-flex items-center justify-center px-10 py-4 border border-accent-gold overflow-hidden transition-all duration-500 hover:bg-accent-gold focus:outline-none shadow-[0_0_15px_rgba(212,175,55,0.1)]">
        <div class="absolute inset-0 bg-accent-gold translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out -z-10"></div>
        <span class="font-serif text-accent-gold group-hover:text-black uppercase tracking-widest text-sm md:text-base transition-colors duration-500">
          {ui["error.btn"]}
        </span>
      </a>

    </div>
  </section>

</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(() => {
      const content = document.getElementById('error-content');
      if(content) {
        content.classList.remove('opacity-0', 'translate-y-10');
      }
    }, 150);
  });
</script>