---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { menuData } from '../data/menu.js';

const lang = 'mk' as 'mk' | 'en'; 
const currency = lang === 'en' ? 'den.' : 'ден.';

const mainCategories = Object.entries(menuData);
---

<BaseLayout title={lang === 'en' ? "Menu | Sky Restaurant" : "Мени | Скај Ресторан"} lang={lang}>
  
  <!-- Cista pozadina bez sijalica i glow efekata -->
  <main class="relative min-h-screen bg-lightbrown pt-24 pb-16 text-dark font-sans overflow-hidden">
    
    <div class="max-w-6xl mx-auto px-4 relative z-10">
      
      <!-- 1. Heading (Usklađen sa ostalim sekcijama) -->
      <div class="flex flex-col items-center text-center mb-16">
        <div class="flex items-center justify-center gap-4 md:gap-6 mb-6 w-full">
          <div class="w-16 md:w-20 h-[1px] bg-gradient-to-r from-transparent to-accent-gold"></div>
          <span class="text-accent-gold font-display text-3xl md:text-4xl lowercase drop-shadow-sm whitespace-nowrap">
            {lang === 'en' ? 'menu' : 'мени'}
          </span>
          <div class="w-16 md:w-20 h-[1px] bg-gradient-to-l from-transparent to-accent-gold"></div>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-medium text-dark uppercase tracking-widest leading-[1.1]">
          {lang === 'en' ? 'Selection' : 'Селекција'}
        </h1>
      </div>

      <!-- 2. Main Tabs (Poboljšan kontrast) -->
      <div class="flex justify-center gap-12 md:gap-24 mb-16">
        {mainCategories.map(([key, data], index) => (
          <button 
            class={`main-tab group flex flex-col items-center gap-4 px-6 py-2 transition-all duration-300 border-b-4 
              ${index === 0 ? 'border-darkbrown opacity-100' : 'border-transparent opacity-60 hover:opacity-100 hover:border-darkbrown/50'}`}
            data-main-cat={key}
          >
            <img 
              src={`/icons/${key === 'hrana' ? 'food' : 'drinks'}.png`} 
              alt={key} 
              class={`w-12 h-12 md:w-14 md:h-14 object-contain transition-all duration-300 ${index === 0 ? 'grayscale-0' : 'grayscale group-hover:grayscale-0'}`} 
            />
            <span class={`font-serif text-base md:text-lg tracking-[0.15em] uppercase transition-colors ${index === 0 ? 'text-darkbrown font-semibold' : 'text-dark'}`}>
              {(data as any).title[lang]}
            </span>
          </button>
        ))}
      </div>

      <!-- Content Sections -->
      <div id="menu-content-wrapper">
        {mainCategories.map(([mainKey, mainData], mainIndex) => (
          <section id={`section-${mainKey}`} class={`main-section ${mainIndex !== 0 ? 'hidden' : ''}`}>
            
            <!-- 3. Slajder (Strelice izvučene van skrola) -->
            <div class="w-full max-w-5xl mx-auto flex items-center justify-between gap-2 md:gap-4 mb-14">
              
              <!-- Strelica Levo -->
              <button class="scroll-left shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-white border border-dark/10 text-darkbrown hover:bg-darkbrown hover:text-white transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
              </button>

              <!-- Skrol Kontejner -->
              <div class="slider-container flex-1 flex overflow-x-auto scrollbar-hide gap-3 py-2 px-1 snap-x justify-start md:justify-center [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none] scroll-smooth">
                {Object.entries((mainData as any).subCategories).map(([subKey, subData], subIndex) => (
                  <button 
                    class={`sub-tab shrink-0 snap-center px-6 py-2 text-xs md:text-sm tracking-[0.15em] uppercase transition-all duration-300 rounded-sm
                      ${subIndex === 0 
                        ? 'bg-darkbrown text-white font-medium shadow-md' 
                        : 'bg-white text-dark/70 border border-dark/10 hover:border-darkbrown/50 hover:text-darkbrown'
                      }`}
                    data-parent={mainKey}
                    data-sub-cat={subKey}
                  >
                    {(subData as any).title[lang]}
                  </button>
                ))}
              </div>

              <!-- Strelica Desno -->
              <button class="scroll-right shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-white border border-dark/10 text-darkbrown hover:bg-darkbrown hover:text-white transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </button>
            </div>

            <!-- Product Grids -->
            <div class="relative min-h-[400px]">
              {Object.entries((mainData as any).subCategories).map(([subKey, subData], subIndex) => (
                <div 
                  id={`grid-${mainKey}-${subKey}`} 
                  class={`product-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 transition-opacity duration-500 ${subIndex !== 0 ? 'hidden opacity-0' : 'opacity-100'}`}
                >
                  {(subData as any).items.map((item: any) => (
                    <div class="bg-white border border-black/5 hover:border-darkbrown/30 transition-all duration-500 p-8 flex flex-col items-center text-center justify-between h-full min-h-[220px] rounded-sm group shadow-sm hover:shadow-lg hover:-translate-y-1">
                      
                      <div class="flex flex-col items-center w-full">
                        <h3 class="font-serif text-lg md:text-xl text-dark group-hover:text-darkbrown transition-colors tracking-widest uppercase mb-4 font-semibold">
                          {item.name[lang]}
                        </h3>
                        
                        {item.description[lang] && (
                          <p class="text-xs md:text-sm text-dark/60 font-sans font-medium leading-relaxed max-w-[90%]">
                            {item.description[lang]}
                          </p>
                        )}
                      </div>

                      <!-- 4. Cene sa darkbrown strelicama -->
                      <div class="mt-8 flex items-center gap-4 w-full justify-center">
                        <div class="w-8 h-[1px] bg-darkbrown/30 group-hover:bg-darkbrown transition-colors"></div>
                        <span class="text-darkbrown font-bold text-xl tracking-wider">
                          {item.price} <span class="text-xs text-darkbrown/70 ml-1 uppercase">{currency}</span>
                        </span>
                        <div class="w-8 h-[1px] bg-darkbrown/30 group-hover:bg-darkbrown transition-colors"></div>
                      </div>
                      
                    </div>
                  ))}
                </div>
              ))}
            </div>

          </section>
        ))}
      </div>

    </div>
  </main>

  <Contact lang={lang} />
  <Footer lang={lang} />
</BaseLayout>

<!-- Odvojena TypeScript logika -->
<script src="../scripts/menu.ts"></script>