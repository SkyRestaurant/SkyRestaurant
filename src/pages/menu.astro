---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { menuData } from '../data/menu.js';

const lang = 'mk' as 'mk' | 'en'; 
const currency = lang === 'en' ? 'den.' : 'ден.';

// Čupamo direktno Hranu i Piće
const hranaData = menuData['hrana'];
const pijalociData = menuData['pice'];

const mainCategories = [
  { key: 'hrana', data: hranaData },
  { key: 'pice', data: pijalociData }
];
---

<BaseLayout title={lang === 'en' ? "Menu | Sky Restaurant" : "Мени | Скај Ресторан"} lang={lang}>
  
  <main class="relative min-h-screen bg-lightbrown pt-24 pb-24 text-dark font-sans overflow-hidden z-0">
    
    <!-- Tanki arhitektonski krugovi -->
    <div class="absolute top-0 left-[-20%] w-[60vw] h-[60vw] rounded-full border-[0.5px] border-darkbrown/20 pointer-events-none -z-10"></div>
    <div class="absolute top-[30%] right-[-10%] w-[40vw] h-[40vw] rounded-full border-[0.5px] border-darkbrown/20 pointer-events-none -z-10"></div>
    <div class="absolute bottom-[-10%] left-1/3 w-[70vw] h-[70vw] rounded-full border-[0.5px] border-darkbrown/15 pointer-events-none -z-10"></div>

    <div class="max-w-6xl mx-auto px-4 relative z-10">
      
      <!-- Heading -->
      <div class="flex flex-col items-center text-center mb-12">
        <div class="flex items-center justify-center gap-4 md:gap-6 mb-4 w-full">
          <div class="w-12 md:w-16 h-[1px] bg-gradient-to-r from-transparent to-accent-gold"></div>
          <span class="text-accent-gold font-display text-3xl md:text-4xl lowercase drop-shadow-sm whitespace-nowrap">
            {lang === 'en' ? 'menu' : 'мени'}
          </span>
          <div class="w-12 md:w-16 h-[1px] bg-gradient-to-l from-transparent to-accent-gold"></div>
        </div>
        <h1 class="font-serif text-5xl md:text-6xl font-medium text-dark uppercase tracking-widest leading-[1.1]">
          {lang === 'en' ? 'Selection' : 'ИЗБОР'}
        </h1>
      </div>

      <!-- Fiksirani Beli Kontejner za Hrana / Piće -->
      <div class="bg-white shadow-sm border border-darkbrown/5 rounded-sm max-w-2xl mx-auto py-6 px-4 flex justify-center gap-12 md:gap-24 mb-16">
        {mainCategories.map(({ key, data }, index) => (
          <button 
            class={`main-tab flex flex-col items-center gap-3 px-6 pb-2 transition-all duration-300 border-b-2 outline-none
              ${index === 0 
                ? 'border-darkbrown opacity-100 is-active' 
                : 'border-transparent opacity-50 hover:opacity-100 hover:border-darkbrown/40'}`}
            data-main-cat={key}
          >
            <img 
              src={`/icons/${key === 'hrana' ? 'food' : 'drinks'}.png`} 
              alt={key} 
              class={`tab-icon w-10 h-10 md:w-12 md:h-12 object-contain transition-all duration-300 ${index === 0 ? 'grayscale-0' : 'grayscale'}`} 
            />
            <span class={`tab-text font-serif text-sm md:text-base tracking-widest uppercase transition-colors ${index === 0 ? 'text-darkbrown font-bold' : 'text-dark/70'}`}>
              {(data as any).title[lang]}
            </span>
          </button>
        ))}
      </div>

      <!-- Content Sections -->
      <div id="menu-content-wrapper">
        {mainCategories.map(({ key: mainKey, data: mainData }, mainIndex) => (
          <div 
            class={`main-section ${mainIndex === 0 ? 'block' : 'hidden'} w-full`} 
            id={`section-${mainKey}`}
          >
            
            <!-- Slajder Podkategorija (Strelice prisutne na svim ekranima, ubačene u krugove) -->
            <div class="relative w-full max-w-4xl mx-auto mb-10 px-10 md:px-0">
              
              <!-- Strelica Levo -->
              <button class="scroll-left absolute left-0 md:-left-12 lg:-left-16 top-1/2 -translate-y-1/2 z-10 flex items-center justify-center w-8 h-8 rounded-full bg-white shadow-sm border border-darkbrown/10 text-darkbrown hover:bg-darkbrown hover:text-white transition-all focus:outline-none">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
              </button>

              <!-- Kontejner koji se skrola -->
              <div class="slider-container flex overflow-x-auto gap-2 md:gap-4 py-2 snap-x scrollbar-hide scroll-smooth [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none] [mask-image:linear-gradient(to_right,transparent,black_15px,black_calc(100%-15px),transparent)] px-2">
                {Object.entries((mainData as any).subCategories).map(([subKey, subData], subIndex) => (
                  <button 
                    class={`sub-tab shrink-0 snap-center px-6 py-2 text-xs md:text-sm tracking-widest uppercase transition-all duration-300 rounded-sm outline-none
                      ${subIndex === 0 
                        ? 'bg-gradient-to-tr from-darkbrown to-accent-gold text-white font-medium shadow-md is-active' 
                        : 'bg-transparent text-dark/70 hover:text-darkbrown hover:bg-darkbrown/5'
                      }`}
                    data-parent={mainKey}
                    data-sub-cat={subKey}
                  >
                    {(subData as any).title[lang]}
                  </button>
                ))}
              </div>

              <!-- Strelica Desno -->
              <button class="scroll-right absolute right-0 md:-right-12 lg:-right-16 top-1/2 -translate-y-1/2 z-10 flex items-center justify-center w-8 h-8 rounded-full bg-white shadow-sm border border-darkbrown/10 text-darkbrown hover:bg-darkbrown hover:text-white transition-all focus:outline-none">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </button>
            </div>

            <!-- Product Grids (Vraćeno na darkbrown i jasno čitljivo) -->
            <div class="relative w-full">
              {Object.entries((mainData as any).subCategories).map(([subKey, subData], subIndex) => (
                <div 
                  id={`grid-${mainKey}-${subKey}`} 
                  class={`product-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 transition-opacity duration-300 ${subIndex !== 0 ? 'hidden opacity-0' : 'opacity-100'}`}
                >
                  {(subData as any).items.map((item: any) => (
                    <div class="bg-white p-6 flex flex-col items-center text-center justify-between rounded-sm shadow-sm h-full min-h-[160px] border border-darkbrown/5 hover:border-darkbrown/20 transition-colors">
                      
                      <div class="w-full mb-3">
                        <h3 class="font-serif text-base md:text-lg text-darkbrown tracking-widest uppercase mb-2 font-bold">
                          {item.name[lang]}
                        </h3>
                        {item.description[lang] && (
                          <!-- Opis ostaje tamno siv zbog čitljivosti, ne braon -->
                          <p class="text-xs text-dark/80 font-sans leading-relaxed max-w-[95%] mx-auto font-medium">
                            {item.description[lang]}
                          </p>
                        )}
                      </div>

                      <div class="mt-auto flex items-center gap-3 justify-center w-full">
                        <div class="w-8 h-[1px] bg-darkbrown/30"></div>
                        <span class="text-darkbrown font-bold text-lg md:text-xl tracking-wider">
                          {item.price} <span class="text-xs text-darkbrown/70 ml-1 font-normal lowercase">{currency}</span>
                        </span>
                        <div class="w-8 h-[1px] bg-darkbrown/30"></div>
                      </div>
                      
                    </div>
                  ))}
                </div>
              ))}
            </div>

          </div>
        ))}
      </div>

    </div>
  </main>

  <Contact lang={lang} />
  <Footer lang={lang} />
</BaseLayout>

<script src="../scripts/menu.ts"></script>