---
// src/layouts/BaseLayout.astro
import Navbar from '../components/Navbar.astro';
import '../styles/global.css'; // OVO JE POKRENULO TAILWIND!

interface Props {
  title: string;
  description?: string;
  lang?: 'mk' | 'en';
}

// Izvlačimo props koje prosleđujemo iz svake stranice (index.astro, menu.astro itd.)
const { 
  title, 
  description = "Sky Restaurant & Pool Bar - Вкус, забава и летна магија.", 
  lang = "mk" 
} = Astro.props;

// Definišemo osnovni URL za Open Graph
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://skyrestaurant.mk');
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <!-- Slike restorana u public/img/ za share preview -->
    <meta property="og:image" content={new URL('/img/sky-og-image.jpg', Astro.url)} />

    
    <!-- Google Fonts dodajemo ovde ako zatreba -->
  </head>

  <!-- Globalni stil na body-ju -->
  <body class="bg-[#f8f6f0] text-[#333333] antialiased font-sans min-h-screen flex flex-col overflow-x-hidden">
    
    <Navbar lang={lang} />

    <main class="flex-grow">
      <slot />
    </main>

    <!-- Back to Top Button -->
    <button 
      id="back-to-top" 
      class="fixed bottom-8 right-8 z-50 flex items-center justify-center w-12 h-12 bg-dark text-lightbrown rounded-sm opacity-0 translate-y-10 pointer-events-none transition-all duration-500 hover:bg-darkbrown hover:text-white shadow-xl focus:outline-none"
      aria-label="Back to top"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
      </svg>
    </button>

  <script src="../scripts/baselayout.ts"></script>
  </body>
</html>