---
// src/components/Services.astro
import { Image } from 'astro:assets';
import mk from '../i18n/mk.json';
import en from '../i18n/en.json';

import imgFood from '../assets/services/food.jpg';
import imgPool from '../assets/services/pool.jpg';
import imgEvents from '../assets/services/events.jpg';

interface Props {
  lang: 'mk' | 'en';
}

const { lang } = Astro.props;
const ui = lang === 'en' ? en : mk;

const services = [
  { img: imgFood, title: ui["services.card1.title"], desc: ui["services.card1.desc"] },
  { img: imgPool, title: ui["services.card2.title"], desc: ui["services.card2.desc"] },
  { img: imgEvents, title: ui["services.card3.title"], desc: ui["services.card3.desc"] },
];
---

<section id="services" class="w-full bg-lightbrown pt-12 pb-24 md:py-32 px-4 relative z-10 overflow-clip -mt-px">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none opacity-[0.03] select-none">
    <span class="font-display text-[15rem] md:text-[25rem] text-dark whitespace-nowrap">Sky Bar</span>
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    <div class="flex flex-col items-center text-center mb-20 animate-on-scroll opacity-0 translate-y-10 transition-all duration-[1200ms] ease-out">
      <div class="flex items-center justify-center gap-6 mb-4 w-full">
        <div class="w-16 md:w-24 h-[1px] bg-gradient-to-r from-transparent to-accent-gold"></div>
        <span class="text-accent-gold font-display text-3xl md:text-4xl lowercase drop-shadow-sm">{ui["services.tag"]}</span>
        <div class="w-16 md:w-24 h-[1px] bg-gradient-to-l from-transparent to-accent-gold"></div>
      </div>
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-dark uppercase tracking-widest">
        {ui["services.title"]}
      </h2>
    </div>

    <div class="flex flex-col m-auto md:max-w-4/5 lg:max-w-1/1 lg:grid lg:grid-cols-3 gap-8 lg:gap-12">
      {services.map((service, index) => (
        <div 
          class={`group w-full aspect-[4/5] rounded-sm overflow-hidden bg-black shadow-xl shadow-dark/10 lg:relative lg:top-auto animate-on-scroll opacity-0 translate-y-12 transition-all duration-[1200ms] ${index > 0 ? 'mobile-instant' : ''}`}
          style={`transition-delay: ${index * 200}ms;`}
        >
          <Image 
            src={service.img}
            alt={service.title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1500ms] group-hover:scale-110"
          />

          <div class="absolute inset-0 bg-gradient-to-t from-dark/95 via-dark/30 to-transparent transition-opacity duration-500"></div>

          <div class="absolute inset-4 border border-accent-gold/40 lg:border-accent-gold/0 lg:group-hover:border-accent-gold/40 transition-colors duration-700 z-10 pointer-events-none"></div>

          <div class="absolute bottom-0 left-0 w-full p-8 flex flex-col justify-end z-20 translate-y-0 lg:translate-y-4 lg:group-hover:translate-y-0 transition-transform duration-500 ease-out">
            <h3 class="font-serif text-2xl md:text-3xl text-white mb-3 tracking-wide drop-shadow-md">
              {service.title}
            </h3>
            
            <div class="w-16 lg:w-8 h-[2px] bg-accent-gold mb-4 lg:group-hover:w-16 transition-all duration-500 ease-out"></div>
            
            <p class="font-sans text-sm text-lightbrown opacity-100 lg:opacity-0 lg:group-hover:opacity-100 transition-opacity duration-500 delay-100 leading-relaxed drop-shadow-sm font-medium">
              {service.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  @media (max-width: 1024px) {
    .mobile-instant {
      opacity: 1 !important;
      transform: translateY(0) !important;
      transition-delay: 0ms !important;
    }
  }
</style>

<script src="../scripts/services.ts"></script>