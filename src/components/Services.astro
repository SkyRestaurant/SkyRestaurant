---
// src/components/Services.astro
import { Image } from 'astro:assets';
import mk from '../i18n/mk.json';
import en from '../i18n/en.json';

import imgFood from '../assets/services/food.jpg';
import imgPool from '../assets/services/pool.jpg';
import imgEvents from '../assets/services/events.jpg';

interface Props {
  lang: 'mk' | 'en';
}

const { lang } = Astro.props;
const ui = lang === 'en' ? en : mk;

const services = [
  { img: imgFood, title: ui["services.card1.title"], desc: ui["services.card1.desc"] },
  { img: imgPool, title: ui["services.card2.title"], desc: ui["services.card2.desc"] },
  { img: imgEvents, title: ui["services.card3.title"], desc: ui["services.card3.desc"] },
];
---

<section id="services" class="w-full bg-zinc-950 py-24 md:py-32 px-4 border-t border-accent-gold/10 relative z-10 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-[0.03] mix-blend-screen" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

  <div class="max-w-7xl mx-auto">
    
    <div class="flex flex-col items-center text-center mb-20 animate-on-scroll opacity-0 translate-y-10 transition-all duration-[1200ms] ease-out">
      <div class="flex items-center justify-center gap-4 mb-4">
        <div class="w-10 h-[1px] bg-accent-gold"></div>
        <span class="text-accent-gold tracking-[0.3em] uppercase text-[10px] font-bold">{ui["services.tag"]}</span>
        <div class="w-10 h-[1px] bg-accent-gold"></div>
      </div>
      <h2 class="font-serif text-4xl md:text-5xl font-light text-white uppercase tracking-wider">
        {ui["services.title"]}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {services.map((service, index) => (
        <div 
          class="group relative w-full aspect-[4/5] rounded-sm overflow-hidden bg-black shadow-2xl animate-on-scroll opacity-0 translate-y-12 transition-all duration-[1200ms] ease-out"
          style={`transition-delay: ${index * 200}ms;`}
        >
          <Image 
            src={service.img} 
            alt={service.title} 
            class="absolute inset-0 w-full h-full object-cover transition-all duration-[800ms] group-hover:scale-110 opacity-70 saturate-50 group-hover:opacity-100 group-hover:saturate-100"
          />
          
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent transition-opacity duration-500"></div>
          
          <div class="absolute inset-3 border border-accent-gold/0 group-hover:border-accent-gold/50 transition-colors duration-700 z-10 pointer-events-none"></div>

          <div class="absolute bottom-0 left-0 w-full p-8 flex flex-col justify-end z-20 translate-y-4 group-hover:translate-y-0 transition-transform duration-500 ease-out">
            <h3 class="font-serif text-2xl lg:text-3xl text-white mb-3 tracking-wide drop-shadow-md">
              {service.title}
            </h3>
            <div class="w-8 h-[2px] bg-accent-gold mb-4 group-hover:w-16 transition-all duration-500 ease-out"></div>
            <p class="font-sans text-sm text-gray-200 opacity-80 group-hover:opacity-100 transition-opacity duration-500 leading-relaxed drop-shadow-sm">
              {service.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script src="../scripts/services.ts"></script>