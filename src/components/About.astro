---
// src/components/About.astro
import { Image } from 'astro:assets';
import mk from '../i18n/mk.json';
import en from '../i18n/en.json';

// Uvozimo sliku za About sekciju
import imgAbout from '../assets/services/food.jpg';

interface Props {
  lang: 'mk' | 'en';
}

const { lang } = Astro.props;
const ui = lang === 'en' ? en : mk;
---

<section id="about" class="w-full bg-lightbrown py-24 md:py-32 px-4 relative z-10 overflow-hidden">
  
  <!-- Suptilni pozadinski element za razbijanje monotonije -->
  <div class="absolute -left-40 top-10 w-[500px] h-[500px] rounded-full bg-accent-gold/10 blur-[100px] pointer-events-none mix-blend-multiply"></div>
  <div class="absolute -right-20 -bottom-20 w-[400px] h-[400px] rounded-full border border-darkbrown/10 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <!-- Leva strana: Tekst (Centrirano na mobilnom, levo na desktopu) -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left about-animate opacity-0 translate-y-10 transition-all duration-[1200ms] ease-out">
        
        <!-- Tag sa gradient linijama -->
        <div class="flex items-center justify-center md:justify-start gap-4 md:gap-6 mb-8 w-full">
          <!-- Leva linija (Uvek vidljiva, bledi ka levo) -->
          <div class="w-16 md:w-20 h-[1px] bg-gradient-to-r from-transparent to-accent-gold"></div>
          
          <span class="text-accent-gold font-display text-3xl md:text-4xl lowercase drop-shadow-sm whitespace-nowrap">
            {ui["about.tag"]}
          </span>
          
          <!-- Desna linija (Samo na mobilnom, bledi ka desno) -->
          <div class="w-16 h-[1px] bg-gradient-to-l from-transparent to-accent-gold"></div>
        </div>

        <!-- Naslov i podnaslov -->
        <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-medium text-dark uppercase tracking-widest mb-4 leading-[1.1]">
          {ui["about.title"]}
        </h2>
        <p class="font-display text-3xl md:text-4xl text-darkbrown mb-10 tracking-wider lowercase">
          {ui["about.subtitle"]}
        </p>

        <!-- Paragrafi -->
        <div class="space-y-6 text-dark/70 font-sans text-sm md:text-base leading-relaxed tracking-wide font-medium mb-12 max-w-2xl mx-auto md:mx-0">
          <p>{ui["about.text_1"]}</p>
          <p>{ui["about.text_2"]}</p>
        </div>

        <!-- Premium Solid Dugme -->
        <div class="w-full flex justify-center md:justify-start">
          <a 
            href="#contact" 
            class="group relative inline-flex items-center justify-center px-10 py-4 text-xs uppercase tracking-[0.2em] font-bold text-lightbrown bg-dark overflow-hidden transition-all duration-500 hover:bg-darkbrown hover:shadow-xl"
          >
            <span class="relative z-10 transition-transform duration-500 group-hover:scale-105">
              {ui["about.btn"]}
            </span>
          </a>
        </div>
      </div>

      <!-- Desna strana: Slika sa offset okvirom -->
      <div class="relative w-full max-w-md mx-auto lg:max-w-none about-animate opacity-0 translate-y-12 transition-all duration-[1200ms] ease-out delay-200">
        <!-- Zlatno-braon okvir (pomeren iza slike) -->
        <div class="absolute inset-0 border border-darkbrown/30 translate-x-4 translate-y-4 md:translate-x-6 md:translate-y-6 z-0 transition-transform duration-700 hover:translate-x-2 hover:translate-y-2"></div>
        
        <!-- Glavna slika -->
        <div class="relative z-10 w-full aspect-[4/5] overflow-hidden bg-lightbrown shadow-2xl shadow-dark/20">
          <Image 
            src={imgAbout} 
            alt={ui["about.title"]} 
            class="w-full h-full object-cover transition-transform duration-[2000ms] hover:scale-105"
          />
          <!-- Suptilni topli overlay za dubinu -->
          <div class="absolute inset-0 bg-darkbrown/5 pointer-events-none mix-blend-overlay"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<script src="../scripts/about.ts"></script>