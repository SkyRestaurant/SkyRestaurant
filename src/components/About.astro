---
// src/components/About.astro
import { Image } from 'astro:assets';
import mk from '../i18n/mk.json';
import en from '../i18n/en.json';

// Uvozimo sliku za About sekciju
import imgAbout from '../assets/services/food.jpg';

interface Props {
  lang: 'mk' | 'en';
}

const { lang } = Astro.props;
const ui = lang === 'en' ? en : mk;
---

<!-- Koristimo tamniju boju #0a0a0a da napravimo kontrast u odnosu na Services sekciju -->
<section id="about" class="w-full bg-[#0a0a0a] py-24 md:py-32 px-4 relative z-10 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <!-- Leva strana: Tekst -->
      <div class="flex flex-col about-animate opacity-0 translate-y-10 transition-all duration-[1200ms] ease-out">
        
        <!-- Tag -->
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-[1px] bg-accent-gold"></div>
          <span class="text-accent-gold tracking-[0.3em] uppercase text-[10px] font-bold">{ui["about.tag"]}</span>
        </div>

        <!-- Naslov i podnaslov -->
        <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-white uppercase tracking-wide mb-4 leading-tight">
          {ui["about.title"]}
        </h2>
        <p class="font-display text-2xl md:text-3xl text-accent-gold mb-10 tracking-wider lowercase">
          {ui["about.subtitle"]}
        </p>

        <!-- Paragrafi (Puno line-height prostora za premium izgled) -->
        <div class="space-y-6 text-gray-400 font-sans text-sm md:text-base leading-relaxed tracking-wide font-light mb-12">
          <p>{ui["about.text_1"]}</p>
          <p>{ui["about.text_2"]}</p>
        </div>

        <!-- Dugme -->
        <div>
          <a 
            href="#contact" 
            class="group inline-flex items-center gap-4 border-b border-accent-gold pb-2 uppercase tracking-[0.2em] text-xs font-bold text-white transition-all hover:text-accent-gold"
          >
            {ui["about.btn"]}
            <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
          </a>
        </div>
      </div>

      <!-- Desna strana: Slika sa offset okvirom -->
      <div class="relative w-full max-w-md mx-auto lg:max-w-none about-animate opacity-0 translate-y-12 transition-all duration-[1200ms] ease-out delay-200">
        <!-- Zlatni okvir (pomeren iza slike) -->
        <div class="absolute inset-0 border border-accent-gold/40 translate-x-4 translate-y-4 md:translate-x-6 md:translate-y-6 z-0"></div>
        
        <!-- Glavna slika -->
        <div class="relative z-10 w-full aspect-[4/5] overflow-hidden bg-[#15120f] shadow-2xl">
          <Image 
            src={imgAbout} 
            alt={ui["about.title"]} 
            class="w-full h-full object-cover transition-transform duration-[2000ms] hover:scale-105"
          />
          <!-- Suptilni tamni overlay preko slike -->
          <div class="absolute inset-0 bg-black/10 pointer-events-none"></div>
        </div>
      </div>

    </div>

  </div>
</section>

<script src="../scripts/about.ts"></script>