---
// src/components/Gallery.astro
import { Image } from 'astro:assets';
import mk from '../i18n/mk.json';
import en from '../i18n/en.json';

interface Props {
  lang: 'mk' | 'en';
}

const { lang } = Astro.props;
const ui = lang === 'en' ? en : mk;

// Učitavanje slika
const imageFiles = import.meta.glob('../assets/gallery/*.{jpeg,jpg,png,webp}', { eager: true });
const images = Object.values(imageFiles).map((file: any) => file.default);
---

<section id="gallery" class="w-full bg-dark py-24 md:py-32 px-4 relative z-10 overflow-hidden">
  
  <!-- Premium Ambience Background (Razbija monotoniju) -->
  <div class="absolute top-0 left-0 w-[60vw] h-[60vw] bg-accent-gold/5 blur-[150px] rounded-full pointer-events-none mix-blend-screen"></div>
  <div class="absolute bottom-0 right-0 w-[50vw] h-[50vw] bg-accent-gold/5 blur-[120px] rounded-full pointer-events-none mix-blend-screen"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    <!-- Naslov sekcije (Prati stil iz Services) -->
    <div class="flex flex-col items-center text-center mb-16 animate-on-scroll opacity-0 translate-y-8 transition-all duration-1000 ease-out">
      <div class="flex items-center justify-center gap-6 mb-4">
        <div class="w-16 md:w-24 h-[1px] bg-gradient-to-r from-transparent to-accent-gold"></div>
        <span class="text-accent-gold font-display text-3xl md:text-4xl lowercase drop-shadow-sm">{ui["gallery.tag"]}</span>
        <div class="w-16 md:w-24 h-[1px] bg-gradient-to-l from-transparent to-accent-gold"></div>
      </div>
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-lightbrown uppercase tracking-widest">
        {ui["gallery.title"]}
      </h2>
    </div>

    <!-- Masonry Grid Galerije -->
    <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 md:gap-6 space-y-4 md:space-y-6 mb-16">
      {images.map((img, index) => (
        <div
          class={`gallery-item group relative w-full overflow-hidden cursor-pointer rounded-sm bg-black break-inside-avoid shadow-lg ${index >= 9 ? 'hidden' : ''}`}
          data-index={index}
          data-src={img.src}
        >
          <Image
            src={img}
            alt={`Sky Restaurant Gallery ${index + 1}`}
            class="w-full h-auto object-cover transition-transform duration-[1000ms] group-hover:scale-110 group-hover:opacity-50"
          />
          
          <!-- Premium Hover Ikonica (Glassmorphism) -->
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none">
            <div class="bg-dark/40 backdrop-blur-md p-4 rounded-full border border-accent-gold/50 shadow-2xl scale-75 group-hover:scale-100 transition-transform duration-500">
              <svg class="w-6 h-6 text-accent-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Show More Dugme -->
    {images.length > 9 && (
      <div class="flex justify-center mt-10">
        <button
          id="toggle-gallery-btn"
          class="relative inline-flex items-center justify-center px-10 py-4 text-xs uppercase tracking-[0.2em] font-bold text-accent-gold border border-accent-gold overflow-hidden transition-all duration-500 hover:bg-accent-gold hover:text-dark focus:outline-none"
          data-show-more={ui["gallery.show_more"]}
          data-show-less={ui["gallery.show_less"]}
        >
          {ui["gallery.show_more"]}
        </button>
      </div>
    )}
  </div>
</section>

<!-- FIX: Lightbox Overlay (Strelice fiksirane za ekran) -->
<div id="lightbox" class="fixed inset-0 z-[100] bg-dark/95 backdrop-blur-xl hidden flex-col justify-center items-center opacity-0 transition-opacity duration-300">
  
  <!-- 'X' Button -->
  <button id="lightbox-close" class="absolute top-4 right-4 md:top-8 md:right-8 z-[110] text-lightbrown hover:text-accent-gold transition-colors p-3 focus:outline-none">
    <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- FIX: Prev Button (Zakucan levo) -->
  <button id="lightbox-prev" class="absolute left-4 md:left-10 top-1/2 -translate-y-1/2 z-[110] bg-accent-gold text-dark hover:bg-lightbrown hover:scale-110 transition-all duration-300 p-3 md:p-4 rounded-full shadow-2xl focus:outline-none">
    <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
    </svg>
  </button>

  <!-- FIX: Next Button (Zakucan desno) -->
  <button id="lightbox-next" class="absolute right-4 md:right-10 top-1/2 -translate-y-1/2 z-[110] bg-accent-gold text-dark hover:bg-lightbrown hover:scale-110 transition-all duration-300 p-3 md:p-4 rounded-full shadow-2xl focus:outline-none">
    <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Image Container (Ovo sada drži samo sliku) -->
  <div class="relative w-full h-full flex items-center justify-center p-4 md:px-24 md:py-12 pointer-events-none">
    <img id="lightbox-img" src="" alt="Gallery Preview" class="max-w-full max-h-full object-contain shadow-2xl scale-95 transition-transform duration-300 pointer-events-auto rounded-sm" />
  </div>
</div>

<script src="../scripts/gallery.ts"></script>