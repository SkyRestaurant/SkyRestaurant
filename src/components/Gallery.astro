---
import { Image } from 'astro:assets';
import mk from '../i18n/mk.json';
import en from '../i18n/en.json';

interface Props {
  lang: 'mk' | 'en';
}

const { lang } = Astro.props;
const ui = lang === 'en' ? en : mk;

const imageFiles = import.meta.glob('../assets/gallery/*.{jpeg,jpg,png,webp}', { eager: true });
const images = Object.values(imageFiles).map((file: any) => file.default);
const imageUrls = images.map(img => img.src);
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section id="gallery" class="w-full bg-navbar-bg py-24 relative z-10 overflow-hidden">
  
  <div class="absolute top-[-10%] left-[-20%] w-[60vw] h-[60vw] rounded-full border-[0.5px] border-darkbrown/15 pointer-events-none -z-10"></div>
  <div class="absolute top-[30%] right-[-10%] w-[40vw] h-[40vw] rounded-full border-[0.5px] border-darkbrown/15 pointer-events-none -z-10"></div>
  <div class="absolute bottom-[-10%] left-1/3 w-[70vw] h-[70vw] rounded-full border-[0.5px] border-darkbrown/10 pointer-events-none -z-10"></div>
  
  <div class="flex flex-col items-center text-center mb-12 px-4 animate-on-scroll opacity-0 translate-y-10 transition-all duration-[1200ms] ease-out relative z-10">
    <div class="flex items-center justify-center gap-6 mb-4 w-full">
      <div class="w-16 md:w-24 h-[1px] bg-gradient-to-r from-transparent to-accent-gold"></div>
      <span class="text-accent-gold font-display text-3xl md:text-4xl lowercase drop-shadow-sm">{ui["gallery.tag"] || "нашата приказна"}</span>
      <div class="w-16 md:w-24 h-[1px] bg-gradient-to-l from-transparent to-accent-gold"></div>
    </div>
    <h2 class="font-serif text-4xl md:text-5xl font-medium text-white uppercase tracking-widest">
      {ui["gallery.title"] || "Галерија"}
    </h2>
  </div>

  <div class="relative w-full group z-10">
    
    <button id="slider-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 hidden md:flex items-center justify-center w-12 h-12 rounded-full bg-black/60 text-white hover:bg-accent-gold hover:text-black transition-all opacity-0 group-hover:opacity-100 focus:outline-none shadow-lg">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
    </button>

    <!-- Ovde prosleđujemo tačan JSON niz slika za JS -->
    <div class="swiper gallery-swiper w-full !overflow-visible" data-images={JSON.stringify(imageUrls)}>
      <div class="swiper-wrapper">
        {images.map((img, index) => (
          <div class="swiper-slide !w-auto">
            <div class="gallery-img-wrapper relative overflow-hidden rounded-sm border border-darkbrown/20 shadow-xl cursor-pointer">
              <!-- Svi hover efekti (scale i bg-transparent) su izbrisani -->
              <img 
                src={img.src} 
                alt={`Gallery ${index}`} 
                class="h-[45vh] md:h-[60vh] w-auto max-w-none object-cover pointer-events-none select-none"
                draggable="false"
              />
              <div class="absolute inset-0 bg-black/10 pointer-events-none"></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <button id="slider-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 hidden md:flex items-center justify-center w-12 h-12 rounded-full bg-black/60 text-white hover:bg-accent-gold hover:text-black transition-all opacity-0 group-hover:opacity-100 focus:outline-none shadow-lg">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    </button>

  </div>

  <!-- LIGHTBOX MODAL -->
  <div id="lightbox" class="fixed inset-0 z-[999999] bg-black/98 hidden flex-col items-center justify-center opacity-0 transition-opacity duration-300 select-none">
    
    <button id="lb-close" class="fixed top-6 right-6 md:top-8 md:right-8 w-12 h-12 flex items-center justify-center text-white bg-black/80 border border-white/10 hover:bg-accent-gold hover:text-black rounded-full transition-all focus:outline-none z-[9999999]">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>

    <button id="lb-prev" class="absolute left-2 md:left-8 top-1/2 -translate-y-1/2 w-10 h-10 md:w-14 md:h-14 flex items-center justify-center text-white bg-black/60 hover:bg-accent-gold hover:text-black rounded-full transition-all focus:outline-none z-[9999999]">
      <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
    </button>

    <img id="lb-img" src="" alt="Fullscreen view" class="max-w-[90vw] max-h-[85vh] w-auto h-auto object-contain rounded-sm shadow-2xl z-[9999998]" />

    <button id="lb-next" class="absolute right-2 md:right-8 top-1/2 -translate-y-1/2 w-10 h-10 md:w-14 md:h-14 flex items-center justify-center text-white bg-black/60 hover:bg-accent-gold hover:text-black rounded-full transition-all focus:outline-none z-[9999999]">
      <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    </button>
      
  </div>
</section>

<script src="../scripts/gallery.ts"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<style>
  .swiper-slide {
    width: auto !important;
  }
</style>