---
// src/components/Gallery.astro
import { Image } from 'astro:assets';
import mk from '../i18n/mk.json';
import en from '../i18n/en.json';

interface Props {
  lang: 'mk' | 'en';
}

const { lang } = Astro.props;
const ui = lang === 'en' ? en : mk;

// Učitavanje slika
const imageFiles = import.meta.glob('../assets/gallery/*.{jpeg,jpg,png,webp}', { eager: true });
const images = Object.values(imageFiles).map((file: any) => file.default).slice(0, 5);
---

<section id="gallery" class="w-full bg-lightbrown py-24 md:py-32 px-4 relative z-10 overflow-hidden">
  <div class="max-w-7xl mx-auto relative z-10">
    
    <!-- Heading -->
    <div class="flex flex-col items-center text-center mb-16 animate-on-scroll opacity-0 translate-y-8 transition-all duration-1000 ease-out">
      <div class="flex items-center justify-center gap-6 mb-4 w-full">
        <div class="w-16 md:w-24 h-[1px] bg-gradient-to-r from-transparent to-accent-gold"></div>
        <span class="text-accent-gold font-display text-3xl md:text-4xl lowercase drop-shadow-sm">{ui["gallery.tag"]}</span>
        <div class="w-16 md:w-24 h-[1px] bg-gradient-to-l from-transparent to-accent-gold"></div>
      </div>
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-dark uppercase tracking-widest">
        {ui["gallery.title"]}
      </h2>
    </div>

    <!-- Editorial Asymmetric Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-2 gap-4 md:gap-6 h-auto md:h-[700px] mb-12">
      
      {/* 1. Velika glavna slika (Levo, 2 kolone, 2 reda) */}
      {images[0] && (
        <div class="gallery-item md:col-span-2 md:row-span-2 group relative overflow-hidden cursor-pointer rounded-sm shadow-sm" data-src={images[0].src}>
          <Image src={images[0]} alt="Gallery 1" class="w-full h-full object-cover transition-transform duration-[1500ms] group-hover:scale-105" />
          <div class="absolute inset-0 bg-dark/10 group-hover:bg-transparent transition-colors duration-500"></div>
        </div>
      )}

      {/* 2. Gornja srednja slika */}
      {images[1] && (
        <div class="gallery-item md:col-span-1 md:row-span-1 group relative overflow-hidden cursor-pointer rounded-sm shadow-sm" data-src={images[1].src}>
          <Image src={images[1]} alt="Gallery 2" class="w-full h-full object-cover transition-transform duration-[1500ms] group-hover:scale-105" />
          <div class="absolute inset-0 bg-dark/10 group-hover:bg-transparent transition-colors duration-500"></div>
        </div>
      )}

      {/* 3. Gornja desna slika (Izdužena) */}
      {images[2] && (
        <div class="gallery-item md:col-span-1 md:row-span-2 group relative overflow-hidden cursor-pointer rounded-sm shadow-sm" data-src={images[2].src}>
          <Image src={images[2]} alt="Gallery 3" class="w-full h-full object-cover transition-transform duration-[1500ms] group-hover:scale-105" />
          <div class="absolute inset-0 bg-dark/10 group-hover:bg-transparent transition-colors duration-500"></div>
        </div>
      )}

      {/* 4. Donja srednja slika */}
      {images[3] && (
        <div class="gallery-item md:col-span-1 md:row-span-1 group relative overflow-hidden cursor-pointer rounded-sm shadow-sm" data-src={images[3].src}>
          <Image src={images[3]} alt="Gallery 4" class="w-full h-full object-cover transition-transform duration-[1500ms] group-hover:scale-105" />
          <div class="absolute inset-0 bg-dark/10 group-hover:bg-transparent transition-colors duration-500"></div>
        </div>
      )}
      
    </div>
  </div>
</section>

<script src="../scripts/gallery.ts"></script>