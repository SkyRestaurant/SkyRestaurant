---
import mk from '../i18n/mk.json';
import en from '../i18n/en.json';

interface Props {
  lang: 'mk' | 'en';
}

const { lang } = Astro.props;
const ui = lang === 'en' ? en : mk;
---

<section id="contact" class="w-full bg-navbar-bg py-24 md:py-32 px-4 relative z-10">
  
  <div class="max-w-7xl mx-auto relative z-10">
    
    <div class="flex flex-col items-center text-center mb-16">
      <div class="flex items-center gap-6 mb-6">
        <div class="w-12 md:w-20 h-[1px] bg-gradient-to-r from-transparent to-accent-gold"></div>
        <span class="text-accent-gold font-display text-2xl md:text-3xl lowercase drop-shadow-sm">{ui["contact.tag"] || "контакт"}</span>
        <div class="w-12 md:w-20 h-[1px] bg-gradient-to-l from-transparent to-accent-gold"></div>
      </div>
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-lightbrown uppercase tracking-widest">
        {ui["contact.title"]}
      </h2>
    </div>

    <div class="w-full bg-dark flex flex-col-reverse lg:flex-row rounded-sm overflow-hidden shadow-2xl border border-white/5">
      
      <div class="w-full lg:w-1/2 p-10 md:p-16 lg:p-20 flex flex-col justify-center">
        
        <h3 class="font-serif text-3xl md:text-4xl text-lightbrown mb-12 tracking-wide">
          Sky Restaurant & Pool Bar
        </h3>

        <div class="space-y-10">
          <div>
            <h4 class="text-accent-gold text-xs uppercase tracking-[0.2em] font-semibold mb-3">
              {ui["contact.address"]}
            </h4>
            <p class="text-lightbrown/80 font-sans text-lg md:text-xl font-light">
              {ui["contact.address_val"]}
            </p>
          </div>

          <div>
            <h4 class="text-accent-gold text-xs uppercase tracking-[0.2em] font-semibold mb-3">
              {ui["contact.phone"]}
            </h4>
            <a href="tel:+38971527184" class="text-lightbrown/80 font-sans text-lg md:text-xl font-light hover:text-accent-gold transition-colors">
              {ui["contact.phone_val"]}
            </a>
          </div>

          <div>
            <h4 class="text-accent-gold text-xs uppercase tracking-[0.2em] font-semibold mb-3">
              {ui["contact.hours"]}
            </h4>
            <p class="text-lightbrown/80 font-sans text-lg md:text-xl font-light">
              {ui["contact.hours_val"]}
            </p>
          </div>

          <div class="w-full h-[1px] bg-white/10 my-4"></div>

          <div>
            <h4 class="text-accent-gold text-xs uppercase tracking-[0.2em] font-semibold mb-4">
              {ui["contact.social"]}
            </h4>
            <div class="flex items-center gap-6">
              <a href="https://www.facebook.com/share/1B3kv8cjQ3/" target="_blank" class="text-lightbrown/80 hover:text-accent-gold hover:-translate-y-1 transition-all duration-300">
                <span class="sr-only">Facebook</span>
                <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
                </svg>
              </a>
              <a href="https://www.instagram.com/sky.restaurant.and.pool.bar?igsh=MTQzdWI5eGFwaXE1Ng==" target="_blank" class="text-lightbrown/80 hover:text-accent-gold hover:-translate-y-1 transition-all duration-300">
                <span class="sr-only">Instagram</span>
                <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="w-full lg:w-1/2 min-h-[400px] lg:min-h-full relative bg-[#1a1a1a]">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d9958.694418619874!2d21.40407506441319!3d42.09167209017661!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x13546b66ef3a969d%3A0xd57ef77cc21508c4!2z0KDQtdGB0YLQvtGA0LDQvSDQodC60LDRmA!5e0!3m2!1smk!2smk!4v1741697628263!5m2!1smk!2smk" 
          class="absolute inset-0 w-full h-full object-cover opacity-90 hover:grayscale-0 hover:opacity-100 transition-all duration-[800ms]" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

    </div>
  </div>
</section>