---
import mk from '../i18n/mk.json';
import en from '../i18n/en.json';

interface Props {
  lang: 'mk' | 'en';
}

const { lang } = Astro.props;
const ui = lang === 'en' ? en : mk;
---

<section id="contact" class="w-full bg-[#15120f] py-24 md:py-32 px-4 relative z-10 border-t border-accent-gold/10 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    
    <div class="flex flex-col items-center text-center mb-16 contact-animate opacity-0 translate-y-10 transition-all duration-[1200ms] ease-out">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-12 h-[1px] bg-accent-gold"></div>
        <span class="text-accent-gold tracking-[0.3em] uppercase text-[10px] font-bold">{ui["contact.tag"]}</span>
        <div class="w-12 h-[1px] bg-accent-gold"></div>
      </div>
      <h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-white uppercase tracking-wide leading-tight">
        {ui["contact.title"]}
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-stretch">
      
      <div class="w-full contact-animate opacity-0 translate-y-12 transition-all duration-[1200ms] ease-out delay-100 flex flex-col">
        <div class="relative w-full h-[400px] lg:h-full min-h-[400px] bg-black p-2 border border-white/5">
          <iframe 
            class="w-full h-full object-cover "
            src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d9958.694418619874!2d21.40407506441319!3d42.09167209017661!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x13546b66ef3a969d%3A0xd57ef77cc21508c4!2z0KDQtdGB0YLQvtGA0LDQvSDQodC60LDRmA!5e0!3m2!1smk!2smk!4v1741697628263!5m2!1smk!2smk" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
        <a href="https://maps.app.goo.gl/zwC889zo3sersmf69" target="_blank" class="mt-4 text-xs font-sans tracking-widest uppercase text-gray-500 hover:text-accent-gold transition-colors inline-block text-right">
          {ui["contact.map_link"]} →
        </a>
      </div>

      <div class="flex flex-col justify-center contact-animate opacity-0 translate-y-12 transition-all duration-[1200ms] ease-out delay-300 bg-[#0a0a0a] p-10 md:p-14 shadow-2xl relative border-l border-accent-gold/20">
        
        <h3 class="font-serif text-3xl md:text-4xl text-white mb-10 tracking-wide">Sky Restaurant & Pool Bar</h3>

        <div class="space-y-8">
          
          <div class="group">
            <h4 class="font-sans text-[10px] tracking-[0.2em] uppercase text-accent-gold mb-2">{ui["contact.address"]}</h4>
            <p class="font-sans text-lg md:text-xl text-gray-300 transition-colors group-hover:text-white">
              {ui["contact.address_val"]}
            </p>
          </div>
          
          <div class="group">
            <h4 class="font-sans text-[10px] tracking-[0.2em] uppercase text-accent-gold mb-2">{ui["contact.phone"]}</h4>
            <a href="tel:+38971527184" class="font-sans text-lg md:text-xl text-gray-300 transition-colors group-hover:text-white inline-block">
              {ui["contact.phone_val"]}
            </a>
          </div>

          <div class="group">
            <h4 class="font-sans text-[10px] tracking-[0.2em] uppercase text-accent-gold mb-2">{ui["contact.hours"]}</h4>
            <p class="font-sans text-lg md:text-xl text-gray-300 transition-colors group-hover:text-white">
              {ui["contact.hours_val"]}
            </p>
          </div>

          <div class="pt-6 mt-6 border-t border-gray-800">
            <h4 class="font-sans text-[10px] tracking-[0.2em] uppercase text-accent-gold mb-4">{ui["contact.social"]}</h4>
            <div class="flex gap-6">
              <a href="https://www.facebook.com/share/1B3kv8cjQ3/" target="_blank" class="text-gray-400 hover:text-accent-gold transition-colors hover:-translate-y-1 transform duration-300">
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878V15.47H7.898v-3.47h2.54V9.845c0-2.506 1.492-3.89 3.775-3.89 1.096 0 2.24.195 2.24.195v2.46h-1.262c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 3.47h-2.33v6.408C18.344 21.128 22 16.991 22 12z" />
                </svg>
              </a>
              <a href="https://www.instagram.com/sky.restaurant.and.pool.bar?igsh=MTQzdWI5eGFwaXE1Ng==" target="_blank" class="text-gray-400 hover:text-accent-gold transition-colors hover:-translate-y-1 transform duration-300">
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2zm0 2A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9A3.5 3.5 0 0 0 20 16.5v-9A3.5 3.5 0 0 0 16.5 4h-9zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm5.5-2.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
                </svg>
              </a>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script src="../scripts/contact.ts"></script>